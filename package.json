{
  "name": "@q1k-oss/context-engine",
  "version": "0.1.1",
  "description": "AI-powered knowledge graph engine that extracts and structures domain knowledge from conversations",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "knowledge-graph",
    "ai",
    "llm",
    "claude",
    "gemini",
    "context",
    "domain-extraction",
    "entity-extraction",
    "graph-database",
    "conversational-ai",
    "express",
    "drizzle",
    "postgresql",
    "sdk",
    "nlp"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/__tests__"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.js"
    },
    "./db/schema": {
      "types": "./dist/db/schema/index.d.ts",
      "import": "./dist/db/schema/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./services/*": {
      "types": "./dist/services/*.d.ts",
      "import": "./dist/services/*.js"
    },
    "./routes/*": {
      "types": "./dist/routes/*.d.ts",
      "import": "./dist/routes/*.js"
    },
    "./middleware/*": {
      "types": "./dist/middleware/*.d.ts",
      "import": "./dist/middleware/*.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepublishOnly": "npm run clean && npm run build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.21.0",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.38.3",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "postgres": "^3.4.5",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/uuid": "^10.0.0",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "dotenv": ">=16.0.0"
  },
  "peerDependenciesMeta": {
    "dotenv": {
      "optional": true
    }
  }
}
